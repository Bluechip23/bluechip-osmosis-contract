# =====================================================================
# osmo-test-5 SHOWCASE deploy config (v2 — reproducible artifacts)
# =====================================================================
# Fresh factory/router deployed from `make optimize-all` artifacts —
# the exact bytes (see artifacts/checksums.txt) a mainnet submission
# would reference. Prod factory build: real 48h admin timelocks,
# 1/hr/address pool-create rate limit.
#
# Differences vs osmo_testnet.env:
#   - STATE_FILE points at a v2 state file (keeps the original stack's
#     state intact)
#   - $20 commit threshold so crossings cost ~22 OSMO at the live rate
#   - cw20/cw721 code IDs pinned to the already-stored uploads (same
#     wasm bytes; mirrors the "reuse audited base code IDs" mainnet plan)
# ---------------------------------------------------------------------

# ---- Chain ----
CHAIN_ID="osmo-test-5"
NODE="https://rpc.osmotest5.osmosis.zone:443"
GAS_PRICES="0.04uosmo"
GAS_ADJUSTMENT="1.3"
KEYRING="test"
FROM="alice"

# ---- Denoms ----
NATIVE_DENOM="uosmo"

# ---- Wasm artifacts ----
ARTIFACTS="artifacts"

# ---- State file ----
STATE_FILE="osmo_testnet_v2.state"

# ---- USD pricing (Osmosis x/twap) ----
# Pool 314 = deepest uosmo / USDC-ibc pool on osmo-test-5 (~$0.92/OSMO).
PRICING_POOL_ID="314"
USD_QUOTE_DENOM="ibc/DE6792CF9E521F6AD6E9A4BDF6225C9571A3B74ACC0A529F92BC5122A39D2E58"
TWAP_WINDOW_SECONDS="600"

# ---- Factory tunables ----
# $20 threshold (USD micro-units) — cheap to cross on testnet while
# exercising identical code paths to a production threshold.
COMMIT_THRESHOLD_LIMIT_USD="20000000"
EMERGENCY_WITHDRAW_DELAY_SECONDS="60"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
MAX_BLUECHIP_LOCK_PER_POOL="25000000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="7"
POOL_CREATION_FEE="1000000"

# ---- Reused code IDs (already stored on osmo-test-5) ----
# Pinned cw-plus / cw-nfts release wasms stored during the first deploy;
# identical bytes, so re-storing would waste gas.
CW20_CODE_ID="13231"
CW721_CODE_ID="13232"

# ---- Sanity-check minimum balance ----
MIN_GAS_BALANCE="15000000"
