# =====================================================================
# osmo-test-5 REHEARSAL factory config (integration_short_timing build)
# =====================================================================
# Deploy with:
#   FACTORY_WASM_FILE=factory-integration.wasm ./deploy_osmosis.sh osmo_rehearsal.env
#
# Purpose: exercise the admin surface that the prod build's 48h
# timelocks make impractical to rehearse — config proposals, pool
# upgrades/migration, pause/unpause, emergency withdraw — plus the
# multi-wallet distribution and creator-earnings claims. Short timings:
# 120s admin timelock, 30s pool-create rate limit. NEVER ship this
# build to a public production chain.
#
# Deliberate config differences vs the showcase stack:
#   - MAX_BLUECHIP_LOCK_PER_POOL=10 OSMO: a ~$20 raise (~22 OSMO net)
#     exceeds the lock cap, forcing a CREATOR_EXCESS_POSITION so
#     ClaimCreatorExcessLiquidity is testable
#   - CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS=0: the excess claim unlocks
#     immediately
# ---------------------------------------------------------------------

# ---- Chain ----
CHAIN_ID="osmo-test-5"
NODE="https://rpc.osmotest5.osmosis.zone:443"
GAS_PRICES="0.04uosmo"
GAS_ADJUSTMENT="1.3"
KEYRING="test"
FROM="alice"

# ---- Denoms ----
NATIVE_DENOM="uosmo"

# ---- Wasm artifacts ----
ARTIFACTS="artifacts"

# ---- State file ----
STATE_FILE="osmo_rehearsal.state"

# ---- USD pricing (Osmosis x/twap) ----
PRICING_POOL_ID="314"
USD_QUOTE_DENOM="ibc/DE6792CF9E521F6AD6E9A4BDF6225C9571A3B74ACC0A529F92BC5122A39D2E58"
TWAP_WINDOW_SECONDS="600"

# ---- Factory tunables ----
COMMIT_THRESHOLD_LIMIT_USD="20000000"
EMERGENCY_WITHDRAW_DELAY_SECONDS="60"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
MAX_BLUECHIP_LOCK_PER_POOL="10000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="0"
POOL_CREATION_FEE="1000000"

# ---- Reused code IDs (stored during v2 showcase deploy) ----
# Same optimized creator-pool/router bytes as the showcase stack; only
# the integration factory wasm is stored fresh by the deploy script.
CW20_CODE_ID="13231"
CW721_CODE_ID="13232"
CREATOR_POOL_CODE_ID="13236"
ROUTER_CODE_ID="13238"

# ---- Sanity-check minimum balance ----
MIN_GAS_BALANCE="15000000"
