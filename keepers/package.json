{
  "name": "bluechip-keepers",
  "version": "0.2.0",
  "private": true,
  "description": "Keeper bot for the Bluechip factory/pool system. Drives ContinueDistribution batches, retries stuck factory notifies, and prunes factory rate limits.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "distribution-keeper": "tsx src/distribution-keeper.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cosmjs/cosmwasm-stargate": "^0.33.1",
    "@cosmjs/proto-signing": "^0.33.1",
    "@cosmjs/stargate": "^0.33.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
