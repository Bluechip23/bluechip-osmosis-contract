# ---------------------------------------------------------------------------
# Bluechip keeper â€” required configuration (Osmosis)
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the real values. Never commit .env.
# Run the keeper with `npm run distribution-keeper`.

# Chain connection â€” osmo-test-5 shown; for mainnet use
# RPC_ENDPOINT=https://rpc.osmosis.zone:443 and CHAIN_ID=osmosis-1.
RPC_ENDPOINT=https://rpc.osmotest5.osmosis.zone:443
CHAIN_ID=osmo-test-5
BECH32_PREFIX=osmo

# Gas settings (Osmosis min gas price is 0.0025uosmo; 0.025 clears fast)
GAS_PRICE=0.025uosmo
GAS_DENOM=uosmo

# Contracts â€” FACTORY_ADDR comes from the deploy script's state file
# (osmo_testnet.state / osmosis_mainnet.state).
FACTORY_ADDRESS=osmo1...factory...
# Comma-separated list of pool addresses to watch. Optional â€” leave empty
# to auto-discover every commit pool from the factory registry each sweep
# (recommended). Set explicitly only to pin the keeper to a subset.
POOL_ADDRESSES=

# Wallet. Keeper calls carry no bounty, so this wallet only ever pays
# gas â€” keep it topped up. Use a DEDICATED throwaway key: never the
# admin/multisig, never the protocol wallet.
KEEPER_MNEMONIC="twelve words of your keeper mnemonic here ..."

# ---------------------------------------------------------------------------
# Optional tuning (defaults shown)
# ---------------------------------------------------------------------------

# Distribution keeper polling. Full sweep of the watch list this often.
# Defaults to 30 min. The keeper automatically speeds up to ~15s between
# sweeps while a pool is actively distributing.
# Each sweep also runs a retry-factory-notify pre-pass: each pool's
# `FactoryNotifyStatus` is queried, and `RetryFactoryNotify` is dispatched
# only on pools that report `pending=true`. No tunable knobs â€” the
# work is gated by the same watch list and DISTRIBUTION_POLL_INTERVAL_MS.
# DISTRIBUTION_POLL_INTERVAL_MS=1800000

# Small delay between pool calls during a sweep (so we don't hammer the
# RPC endpoint). Defaults to 2 seconds.
# DISTRIBUTION_PER_POOL_DELAY_MS=2000

# Rate-limit prune sweep cadence. Once every N distribution sweeps the
# keeper also dispatches factory.PruneRateLimits {}. Default 48 Ã— 30min
# â‰ˆ once a day. Set to 0 to disable entirely.
# PRUNE_EVERY_N_SWEEPS=48

# Per-call work cap passed to PruneRateLimits. Contract enforces a
# hard ceiling of 500; default 100 is plenty for the steady-state
# drift rate. Tune higher only for backlog catch-up after a long
# prune outage.
# PRUNE_BATCH_SIZE=100

# Balance-warning threshold, in GAS_DENOM base units (uosmo here â€” the
# variable name predates the Osmosis move). Below this, the keeper logs
# a WARN on each iteration so you know to top up the wallet's gas.
# MIN_KEEPER_BALANCE_UBLUECHIP=1000000
