# =====================================================================
# osmosis-1 (MAINNET) deploy config
# =====================================================================
# Osmosis mainnet wasm uploads are GOVERNANCE-GATED: either each wasm is
# stored via a StoreCode gov proposal, or governance grants the deployer
# address standing upload permission. See docs/OSMOSIS_DEPLOY.md.
#
# STORE_MODE=gov    -> fill in the *_CODE_ID values below from the passed
#                      proposals; the script only instantiates.
# STORE_MODE=direct -> only valid if the deployer address has been
#                      granted upload permission by governance.
# ---------------------------------------------------------------------

CHAIN_ID="osmosis-1"
NODE="https://rpc.osmosis.zone:443"
GAS_PRICES="0.025uosmo"
GAS_ADJUSTMENT="1.4"
KEYRING="os"
FROM="deployer"

STORE_MODE="gov"
# Fill these from the passed StoreCode proposals (or leave empty and use
# STORE_MODE=direct if governance granted the deployer upload rights):
CREATOR_POOL_CODE_ID=""
FACTORY_CODE_ID=""
ROUTER_CODE_ID=""
# cw20-base and cw721-base are already stored on osmosis-1 by other
# projects; you can reuse an existing audited code ID instead of storing
# your own copies — verify the code hash matches the published release.
CW20_CODE_ID=""
CW721_CODE_ID=""

# ---- Denoms ----
# Pools pair against OSMO; commits are valued in USD via x/twap (below).
NATIVE_DENOM="uosmo"

ARTIFACTS="artifacts"
STATE_FILE="osmosis_mainnet.state"

# ---- USD pricing (Osmosis x/twap) ----
# Pool whose arithmetic TWAP prices uosmo in USD_QUOTE_DENOM. Point this
# at the DEEPEST OSMO/USDC pool on osmosis-1 (verify the current pool id
# and Noble USDC denom on app.osmosis.zone before deploying) — the
# manipulation cost of every USD valuation in the protocol is the cost
# of moving this pool for TWAP_WINDOW_SECONDS.
PRICING_POOL_ID=""
# Noble USDC on osmosis-1:
USD_QUOTE_DENOM="ibc/498A0751C798A0D9A389AA3691123DADA57DAA4FE165D5C75894505B876BA6E4"
TWAP_WINDOW_SECONDS="600"

# ---- Factory tunables ----
# Commit threshold in USD micro-units (6 decimals):
# 25_000_000_000 = $25,000. Committers pay in OSMO; the factory values
# each commit via the x/twap price above.
COMMIT_THRESHOLD_LIMIT_USD="25000000000"
EMERGENCY_WITHDRAW_DELAY_SECONDS="86400"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
# Per-pool max OSMO lock (base units).
MAX_BLUECHIP_LOCK_PER_POOL="25000000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="7"
# Flat pool-creation fee in uosmo (1 OSMO). Zero disables.
POOL_CREATION_FEE="1000000"

# Protocol fee wallet (receives commit fees + creation fees). Defaults
# to the deployer address when unset — set this to the real multisig.
PROTOCOL_WALLET=""

# Minimum uosmo gas balance required before starting.
MIN_GAS_BALANCE="20000000"
