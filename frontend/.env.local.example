# Contract addresses — copy this file to `.env.local` and fill in the
# values from your deployment (see deploy_osmosis.sh / the *.state file
# it writes).
#
# VITE_FACTORY_ADDRESS:  the factory contract instantiated by
#                        deploy_osmosis.sh. Pools are discovered on-chain
#                        via the factory's `pools` registry query, so no
#                        per-pool address list is needed. USD pricing
#                        comes from Osmosis x/twap via the factory —
#                        there is no separate oracle contract.
VITE_FACTORY_ADDRESS=osmo1...
#
# VITE_RPC_ENDPOINT / VITE_REST_ENDPOINT: used by the in-site liquidity
# feature (native GAMM MsgJoinPool/MsgExitPool signing + LP-share supply
# lookup). Point at your target chain — e.g. osmo-test-5:
#   https://rpc.osmotest5.osmosis.zone   /   https://lcd.osmotest5.osmosis.zone
VITE_RPC_ENDPOINT=https://rpc.osmotest5.osmosis.zone
VITE_REST_ENDPOINT=https://lcd.osmotest5.osmosis.zone
