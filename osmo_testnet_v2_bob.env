# Same showcase stack as osmo_testnet_v2.env, but txs are signed by bob.
# Used to create the second pool for the two-hop router test without
# tripping the prod factory's 1/hr/address pool-create rate limit.
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/osmo_testnet_v2.env"
FROM="bob"
