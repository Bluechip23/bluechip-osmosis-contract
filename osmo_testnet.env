# =====================================================================
# osmo-test-5 deploy/test config
# =====================================================================
# Static config for testnet deploys of the stack (factory +
# creator-pool + router). Pools pair against the
# chain's main native asset; the commit threshold is USD-denominated,
# valued via Osmosis x/twap (see the pricing section below).
# ---------------------------------------------------------------------

# ---- Chain ----
CHAIN_ID="osmo-test-5"
NODE="https://rpc.osmotest5.osmosis.zone:443"
GAS_PRICES="0.04uosmo"
GAS_ADJUSTMENT="1.3"
KEYRING="test"

# Test wallet name in the local keyring. The script reads its bech32
# address via `osmosisd keys show`, so this just has to match a
# pre-imported key. Faucet: https://faucet.testnet.osmosis.zone/
FROM="alice"

# ---- Denoms ----
# The chain's main native asset — this is what pools pair against and
# what the commit threshold is denominated in (`bluechip_denom` on the
# factory config). On osmo-test-5 that's uosmo; on Cosmos Hub, uatom;
# on Neutron, untrn.
NATIVE_DENOM="uosmo"

# ---- Wasm artifacts ----
ARTIFACTS="artifacts"

# ---- State file ----
# Runtime values written by the deploy script (code IDs, factory
# address, etc). Subsequent scripts source this in addition to the .env.
STATE_FILE="osmo_testnet.state"

# ---- USD pricing (Osmosis x/twap) ----
# Pool whose arithmetic TWAP prices NATIVE_DENOM in USD_QUOTE_DENOM.
# On testnet, create (or reuse) a NATIVE_DENOM/USD-stable pool and put
# its id here; the factory refuses pool_id 0. The manipulation cost of
# every USD valuation is the cost of moving THIS pool for the window.
PRICING_POOL_ID="314"
USD_QUOTE_DENOM="ibc/DE6792CF9E521F6AD6E9A4BDF6225C9571A3B74ACC0A529F92BC5122A39D2E58"
TWAP_WINDOW_SECONDS="600"

# ---- Factory tunables ----
# Commit threshold in USD micro-units (6 decimals):
# 25_000_000_000 = $25,000. Drop to a few hundred dollars for testnet
# runs so a commit pool can be threshold-crossed quickly.
COMMIT_THRESHOLD_LIMIT_USD="150000000"
# Seconds between EmergencyWithdraw Phase 1 (initiate) and Phase 2 (drain).
# Pinned at factory instantiate; admin-tunable through ProposeConfigUpdate
# (48h timelock). Range: 60 .. 7d. Production default: 86_400 (24h).
EMERGENCY_WITHDRAW_DELAY_SECONDS="60"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
# Per-pool max native-asset lock (25,000 tokens at 6 decimals).
MAX_BLUECHIP_LOCK_PER_POOL="25000000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="7"
# Flat pool-creation fee in base units of NATIVE_DENOM (1 token here).
# Charged on Create; forwarded to the protocol wallet, surplus
# refunded. Zero disables.
POOL_CREATION_FEE="1000000"

# ---- Deploy knobs (optional) ----
# STORE_MODE: "direct" (default) uploads the wasms; "gov" skips uploads
# and requires the *_CODE_ID values below. osmo-test-5 is permissionless,
# so direct is right here.
# STORE_MODE="direct"
# Pre-existing code IDs — leave unset to upload fresh copies. Useful for
# reusing already-stored cw20-base / cw721-base code IDs.
# CW20_CODE_ID=""
# CW721_CODE_ID=""
# CREATOR_POOL_CODE_ID=""
# FACTORY_CODE_ID=""
# ROUTER_CODE_ID=""
# Protocol fee wallet (commit fees + creation fees). Defaults to the
# deployer address when unset — fine on testnet.
# PROTOCOL_WALLET=""

# ---- Sanity-check minimum balance ----
# Minimum uosmo (gas) balance the deploy script requires before it
# starts. Covers wasm uploads (the expensive part), instantiate txs,
# and a few commit-pool tests with comfort room. Faucet gives 10 OSMO
# per request.
MIN_GAS_BALANCE="15000000"
