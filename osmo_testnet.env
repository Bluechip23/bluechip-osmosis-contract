# =====================================================================
# osmo-test-5 deploy/test config
# =====================================================================
# Static config for testnet deploys of the stripped-down stack
# (factory + creator-pool + standard-pool + router). The internal
# oracle, Pyth pusher, expand-economy, and anchor-pool machinery were
# removed — pools pair directly against the chain's main native asset
# and the commit threshold is denominated in that asset.
# ---------------------------------------------------------------------

# ---- Chain ----
CHAIN_ID="osmo-test-5"
NODE="https://rpc.osmotest5.osmosis.zone:443"
GAS_PRICES="0.04uosmo"
GAS_ADJUSTMENT="1.3"
KEYRING="test"

# Test wallet name in the local keyring. The script reads its bech32
# address via `osmosisd keys show`, so this just has to match a
# pre-imported key. Faucet: https://faucet.testnet.osmosis.zone/
FROM="alice"

# ---- Denoms ----
# The chain's main native asset — this is what pools pair against and
# what the commit threshold is denominated in (`bluechip_denom` on the
# factory config). On osmo-test-5 that's uosmo; on Cosmos Hub, uatom;
# on Neutron, untrn.
NATIVE_DENOM="uosmo"

# ---- Wasm artifacts ----
ARTIFACTS="artifacts"

# ---- State file ----
# Runtime values written by the deploy script (code IDs, factory
# address, etc). Subsequent scripts source this in addition to the .env.
STATE_FILE="osmo_testnet.state"

# ---- Factory tunables ----
# Commit threshold in base units of NATIVE_DENOM (6 decimals):
# 25_000_000_000 = 25,000 tokens. Drop to a few hundred tokens for
# testnet runs so a commit pool can be threshold-crossed quickly.
COMMIT_THRESHOLD_LIMIT="25000000000"
# Seconds between EmergencyWithdraw Phase 1 (initiate) and Phase 2 (drain).
# Pinned at factory instantiate; admin-tunable through ProposeConfigUpdate
# (48h timelock). Range: 60 .. 7d. Production default: 86_400 (24h).
EMERGENCY_WITHDRAW_DELAY_SECONDS="60"
COMMIT_FEE_BLUECHIP="0.01"
COMMIT_FEE_CREATOR="0.05"
# Per-pool max native-asset lock (25,000 tokens at 6 decimals).
MAX_BLUECHIP_LOCK_PER_POOL="25000000000"
CREATOR_EXCESS_LIQUIDITY_LOCK_DAYS="7"
# Flat pool-creation fee in base units of NATIVE_DENOM (1 token here).
# Charged on both Create (commit pools) and CreateStandardPool;
# forwarded to the protocol wallet, surplus refunded. Zero disables.
STANDARD_POOL_CREATION_FEE="1000000"

# ---- Sanity-check minimum balance ----
# Minimum uosmo (gas) balance the deploy script requires before it
# starts. Covers wasm uploads (the expensive part), instantiate txs,
# and a few commit-pool tests with comfort room. Faucet gives 10 OSMO
# per request.
MIN_GAS_BALANCE="15000000"
